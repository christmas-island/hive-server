{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "labels": ["dependencies"],
  "postUpdateOptions": ["gomodTidy"],
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchManagers": ["gomod"]
    }
  ],
  "pre-commit": {
    "enabled": true
  },
  "prConcurrentLimit": 3,
  "vulnerabilityAlerts": {
    "labels": ["security"]
  },
  "osvVulnerabilityAlerts": true
}
