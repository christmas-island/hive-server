#!/usr/bin/env bash
# script/integration/test — Run integration tests with ephemeral CockroachDB.
# Requires: cockroach binary (see script/bootstrap)
# Blocked on: CockroachDB migration (#12) — currently runs unit tests as fallback.
set -euo pipefail

cd "$(dirname "$0")/../.."

if ! command -v cockroach &>/dev/null; then
  echo "ERROR: cockroach binary not found. Install from https://www.cockroachlabs.com/docs/releases/" >&2
  echo "       Falling back to unit tests..." >&2
  exec script/test
fi

# TODO: Once #12 (CRDB migration) lands, this will:
# 1. Start ephemeral CockroachDB via cockroach-go/v2/testserver
# 2. Run integration tests with -tags integration
# 3. Tear down on exit
#
# For now, run all tests (unit + any tagged integration).
echo "==> Running integration tests..."
go test -race -count=1 -tags integration ./...

echo "==> Integration tests passed."
