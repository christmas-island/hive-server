#!/usr/bin/env bash
# script/integration/test — Run integration tests against CockroachDB.
#
# If DATABASE_URL is set, tests use that database.
# Otherwise, cockroach-go/v2/testserver auto-downloads and starts an
# ephemeral single-node CockroachDB cluster (~200MB first-run download,
# cached afterwards).
set -euo pipefail

cd "$(dirname "$0")/../.."

echo "==> Running integration tests..."
if [ -n "${DATABASE_URL:-}" ]; then
  echo "    Using DATABASE_URL from environment"
else
  echo "    Ephemeral CockroachDB will be started via testserver"
fi

go test -race -count=1 -tags integration -timeout 300s ./...

echo "==> Integration tests passed."
